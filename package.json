{
  "name": "pos-abadi-jaya",
  "version": "1.0.0",
  "description": "POS Abadi Jaya Desktop Application",
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently \"cd server && npm start\" \"cd client && npm run dev\"",
    "build:client": "cd client && npm run build",
    "start": "electron .",
    "dist": "npm run build:client && electron-builder",
    "postinstall": "cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.2",
    "qrcode": "1.5.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "whatsapp-web.js": "1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.abadijaya.pos",
    "productName": "POS Abadi Jaya",
    "copyright": "Copyright © 2025 Abadi Jaya Copier",
    "directories": {
      "output": "dist-installer"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "POS Abadi Jaya",
      "include": "build/installer.nsh"
    },
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "assets/database-engine",
        "to": "database-engine"
      },
      {
        "from": "server/database/pos_abadi.sql",
        "to": "database/pos_abadi.sql"
      }
    ],
    "files": [
      "client/dist/**/*",
      "server/**/*",
      "electron-main.js",
      "package.json",
      "!server/node_modules/**/*",
      "!client/node_modules/**/*",
      "!server/database/pos.sqlite"
    ],
    "asar": true,
    "npmRebuild": true
  }
}